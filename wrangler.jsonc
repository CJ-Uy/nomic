{
	"name": "nomic",
	"main": ".svelte-kit/cloudflare/_worker.js",
	"compatibility_date": "2024-12-01",
	"compatibility_flags": ["nodejs_compat"],

	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare/",
		"not_found_handling": "single-page-application"
	},

	"observability": {
		"logs": {
			"enabled": true,
			"invocation_logs": true
		},
		"traces": {
			"enabled": false
		}
	}
}
